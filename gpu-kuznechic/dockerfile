FROM nvidia/cuda:12.3.1-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# Ubuntu 22.04 имеет Python 3.10 по умолчанию — используем его
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

# python → python3 (3.10)
RUN ln -sf /usr/bin/python3 /usr/bin/python

WORKDIR /app

RUN pip3 install --no-cache-dir \
    numpy \
    fastapi \
    uvicorn[standard] \
    pydantic \
    gostcrypto

COPY grasshopper_ctr.cu .
COPY grasshopper_module.cu .
COPY setup.py .
COPY tables.bin .
COPY t_table_generation.py .
COPY app.py .

RUN if [ ! -f tables.bin ]; then python t_table_generation.py; fi

# Собираем extension под реальный Python внутри контейнера
RUN python setup.py build && ls -la grasshopper_gpu*.so

COPY grasshopper_worker.py .

EXPOSE 5000

CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "5000", "--workers", "1"]